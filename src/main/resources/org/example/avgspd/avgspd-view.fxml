<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.TextField?>



<VBox fx:id="rootVBox"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.avgspd.AverageSpeedController"
      spacing="15"
      alignment="TOP_CENTER"
      style="-fx-padding: 20; -fx-background-color: #f0f0f0;">

    <!-- Title -->
    <Label fx:id="avgTitle"
           text="Average Speed"
           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <!-- Language Selection Buttons -->
    <HBox spacing="10" alignment="CENTER">
        <Button text="English" onAction="#onENClick" style="-fx-font-weight: bold;"/>
        <Button text="Français" onAction="#onFRClick"/>
        <Button text="Tiếng Việt" onAction="#onVIClick"/>
        <Button text="اردو" onAction="#onURClick"/>
        <Button text="فارسی" onAction="#onFAClick"/>
    </HBox>

    <Separator/>

    <!-- avgSpeed Input Fields -->
    <GridPane hgap="10" vgap="10" alignment="CENTER">
        <Label fx:id="lblDistant" text="Distant (km):" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="tfDistant" promptText="Enter distant" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>

        <Label fx:id="lblTime" text="Time (h):" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="tfTime" promptText="Enter time" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="200"/>

        <Button fx:id="btnCalculate" text="Calculate average" GridPane.columnIndex="0" GridPane.rowIndex="2"
                GridPane.columnSpan="2" onAction="#onCalculateClick" prefWidth="200"/>
    </GridPane>

    <Separator/>

    <!-- Result Display -->
    <Label fx:id="lblResult" text="" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Separator/>

    <!-- Time Display -->
    <Label fx:id="lblLocalTime" text="" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>

</VBox>